#!/usr/bin/env raku

use JSON::Fast;

use File::Find;
use Text::Utils :strip-comment;

use App::DistroLint;

if not @*ARGS {
    print qq:to/HERE/;
    Usage: {$*PROGRAM.basename} </path/to/distro/directory>

    Searches the repository directory for issues affecting 
    normal operation of the distribution's repository.

    Current actions:

    + Reports the distribution's list of other distributions
      being 'used' in the 'META6.json' file's list versus those 
      actually being 'used' in that distro's files. See the README for 
      more details.

      Creates a new META6.json file with all dependencies in the 'depends'
      array in alphabetical order. The file is named 'new-META6.json'
      for your viewing before substituting it for the existing file. 
    HERE
    exit;
}

my $debug = 0;

my $repo-path = @*ARGS.shift // "";
unless $repo-path.IO.d {
   die "confused with \$repo-path: '$repo-path'";
}

LINE: for @*ARGS {

    when $_.IO.d {
        print qq:to/HERE/;
        FATAL: Multiple input paths detected.
                 '$repo-path'
                 '$_'
               Exiting...
        HERE
        exit(1);
    }
    when /^ :i d / {
        ++$debug;
    }
    default {
        print qq:to/HERE/;
        FATAL: Unknown arg '$_'.
               Exiting...
        HERE
        exit(1);
    }
}

# get the current META6.json contents
my $meta = from-json "$repo-path/META6.json".IO.slurp;
# the used modules need to be in one of:
my %h-deps       = @($meta<depends>).map({ $_ => True });
my %h-test-deps  = @($meta<test-depends>).map({ $_ => True });
my %h-build-deps = @($meta<build-depends>).map({ $_ => True });

# check for dups in hashes
my @c1 = (%h-deps.keys       (&) %h-test-deps.keys).keys;
my @c2 = (%h-deps.keys       (&) %h-build-deps.keys).keys;
my @c3 = (%h-build-deps.keys (&) %h-test-deps.keys).keys;
my $dups = @c1.elems + @c2.elems + @c3.elems;

if $dups {
    print q:to/HERE/;
    WARNING: Found $dups duplicate depends entries in the 
             META6.json file.
             Please correct that before continuing.
             Early exit...
    HERE
    exit(1);
}

# combine the hashes
my %mods = %(|%h-deps, |%h-test-deps, |%h-build-deps);

# search the bin, sbin, t, xt, and lib files for used modules
my @dirs = <bin sbin lib t xt>;
my @allfils = [];
for @dirs -> $dir {
    next unless "$repo-path/$dir".IO.d;
    my @fils = find :dir("$repo-path/$dir"), :type('file'), :exclude(/'.'git|'.'precomp/);
    # note there may be dups to clean up
    @allfils.append: @fils;
}

if 0 or $debug {
    say "DEBUG: found the following files of interest:";
    say "  $_" for @allfils;
    if 1 {
        say "DEBUG: Early exit...";
        exit;
    }
}

=begin comment
my @fils  = find :dir("$repo-path/lib"), :name(/\.rakumod/);
my @fils2 = find :dir("$repo-path/bin"), :type('file'), :exclude(/\.git/);
my @fils3 = find :dir("$repo-path/sbin"), :type('file'), :exclude(/\.git/);
my @all   = @fils.append(@fils2).append(@fils3);
=end comment

if $debug {
    say "DEBUG: Found files:";
    say "  $_" for @allfils;
}

# search for used modules
my %used-modules;
my %dups;
FILE: for @allfils -> $fil {
    say "Working file '$fil'" if $debug;

    # a dup would look like:
    # same file, same %result<module>
    my $line-number = 0;
    LINE: for $fil.IO.lines -> $line is copy {
        ++$line-number;
        
        $line = strip-comment $line;
        next LINE unless $line ~~ /\S/;

        # assume multiple modules are used on a single line
        # replace  semicolons with spaces and split on words	
        # note the line MUST start with use|need|require
        next LINE unless $line ~~ /^ \s* [use|need|require] \h /;

        # ignore use Test since it's always available as part of Raku
        if $line ~~ /^ \s* use \h+ Test \h* ';' / { 
            next LINE;
        }

        if $debug {
            say "DEBUG: use line: '$line'";
        }

        my @mods = parse-use-line $line;
        if 0 or $debug {
            say "DEBUG: 'use' lines:";
            say "  $_" for @mods;
        }

        =begin comment
        # parse-use-line takes care of this
        unless @mods.elems %% 2 { # is-even
            say "FATAL: unrecognized line format (expected two parts):";
            say "       $line";
            exit;
        }
        =end comment

        for @mods -> $modstr is copy {
            $modstr .= trim;
            my %result = parse-module-spec $modstr, :$debug;
        }

        =begin comment
        # check for dups: modules with the same module name in the same file
        =end comment
        
        =begin comment
        # it is a 'use' line
        %result<command> = ~$m[0]; # use|need|require
        %result<module>  = ~$m[1]; # module name without adverbs
        %result<auth>    = Nil;
        %result<ver>     = Nil;
        %result<api>     = Nil;
        =end comment
    }
}

# look at the quality issues of the modules found

# compare the two sets of hashes
my $new-meta = $meta;
for %used-modules.keys -> $m {
    unless %mods{$m}:exists {
        say "adding module $m to the revised META6.json file";
        @($new-meta<depends>).push: $m; 
    }
}

# try to sort the depends array
@($new-meta<depends>) .= sort;

say "Revised META6.json for distro '$repo-path':";
say to-json $new-meta, :pretty, :sorted-keys;
my $jfil = 'new-META6.json';
spurt $jfil, to-json($new-meta, :pretty, :sorted-keys);
say "See file '$jfil' for distro '$repo-path'.";
