#!/usr/bin/env raku

use App::DistroLint;

sub MAIN(
    Str:D $repo-path,
    Bool :$debug = False,
) {
    my $root = $repo-path.IO;

    unless $root.d {
        die "FATAL: '$repo-path' is not a directory";
    }

    my $meta-path = $root.add('META6.json');

    unless $meta-path.f {
        die "FATAL: no META6.json found in '$repo-path'";
    }

    my $meta = read-meta6($meta-path);

    my %scan = scan-distribution(
        $root,
        :$debug,
    );

    my @dependencies = @(%scan<dependencies>);
    my @errors       = @(%scan<errors>);

    my %provides = build-provides-map($root);
    my $self-top = primary-top-module(%provides);

    my %classified = classify-dependencies(
        @dependencies,
        $self-top,
    );

    my %clean = canonicalize-meta-dependency-sets(
        :depends(%classified<depends>),
        :build-depends(%classified<build-depends>),
        :test-depends(%classified<test-depends>),
    );

    my %analysis = analyze-meta6(
        $meta,
        :depends(%clean<depends>),
        :build-depends(%clean<build-depends>),
        :test-depends(%clean<test-depends>),
        :%provides,
    );

    my $new-meta-path;
    my $notes-path;

    if %analysis<issues>.elems {
        $new-meta-path = write-new-meta6(
            $meta-path,
            $meta,
            :depends(%clean<depends>),
            :build-depends(%clean<build-depends>),
            :test-depends(%clean<test-depends>),
            :%provides,
        );
    }

    if @errors.elems or %analysis<issues>.elems {
        $notes-path = write-issues-file(
            $root,
            @errors,
            @(%analysis<issues>),
        );
    }

    say '';


    if $new-meta-path.defined {
        say "Wrote proposed META6 correction:";
        say "  $new-meta-path";
    }

    if $notes-path.defined {
        say "Wrote lint notes:";
        say "  $notes-path";
    }

    unless $new-meta-path.defined or $notes-path.defined {
        say "No issues found.";
    }
}
